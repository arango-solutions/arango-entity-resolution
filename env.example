# ArangoDB Configuration
#
# Copy this file to `.env` and set a real password before use. The value below
# is a non-secret placeholder for LOCAL DEVELOPMENT ONLY -- never reuse it for
# any shared or production deployment.
#
# Canonical (preferred)
ARANGO_PASSWORD=CHANGE_ME_local_dev_only

# Backwards-compatible alias (still supported)
ARANGO_ROOT_PASSWORD=CHANGE_ME_local_dev_only
ARANGO_NO_AUTH=false

# Database Configuration
ARANGO_HOST=localhost
ARANGO_PORT=8529
ARANGO_USERNAME=root
ARANGO_DATABASE=entity_resolution

# Test Database Names
TEST_DB_NAME=entity_resolution_test
SAMPLE_DB_NAME=entity_resolution_sample

# Data Directories
LOCAL_DATA_DIR=${HOME}/data
DOCKER_DATA_DIR=/data
